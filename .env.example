# Copy this file to `.env` (no extension change!) and fill in real values.
# Real `.env` is gitignored. Never commit it.

# ----- LLM (DeepSeek by default; swap base URL + model for OpenAI/Ollama) -----
LLM_API_KEY=sk-REPLACE_ME
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# For OpenAI instead:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#
# For local Ollama:
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3.1:8b
#   LLM_API_KEY=ollama

# ----- Sender identity (used in drafts) -----
SENDER_NAME=Your Name
SENDER_HEADLINE=Analyst | open to new roles.
SENDER_LINKEDIN=https://www.linkedin.com/in/your-handle/
SENDER_EMAIL=you@gmail.com

# ----- Email-pattern discovery (Outreach stage 03b) -----
# Hunter.io Domain Search — 25 lookups/month free. Optional: 03b falls back to
# email-format.com scraping when absent.
HUNTER_API_KEY=

# ----- JD resolver (Resume A1 fallback: jd_resolver.py) -----
# Provide EITHER a Brave key OR a Google CSE key + id. Optional: the resolver's
# search tier is skipped when none are set.
BRAVE_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
